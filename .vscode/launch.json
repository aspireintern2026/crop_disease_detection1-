{
  "version": "0.2.0",
  "configurations": [
    {
      "type": "chrome",
      "request": "launch",
      "name": "Launch Chrome against localhost",
      "url": "http://localhost:3000",
      "webRoot": "${workspaceFolder}"
    },
    {
      "type": "node",
      "request": "launch",
      "name": "Debug Dev Server",
      "program": "${workspaceFolder}/node_modules/vite/bin/vite.js",
      "args": ["--port=3000", "--host=0.0.0.0"],
      "cwd": "${workspaceFolder}",
      "protocol": "inspector"
    }
  ]
}
